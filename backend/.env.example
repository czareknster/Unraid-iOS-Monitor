# =============================================================================
# unraid-monitor — example environment file
#
# Copy to `.env` (git-ignored) and fill in your own values:
#     cp backend/.env.example backend/.env
#
# Two copies live side-by-side in a typical deployment:
#   - `backend/.env` on your Mac — read by `deploy.sh` for SSH targets, and
#     may also hold the CF Access pair / PUBLIC_URL for reference.
#   - /mnt/user/appdata/unraid-monitor/backend/.env on the Unraid host —
#     read by the container; only the runtime vars matter there.
#
# Never commit a filled-in copy. See README §6 and §Security model.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend runtime (required by the Node container)
# -----------------------------------------------------------------------------

# 32-byte hex Bearer token. Generate with:  openssl rand -hex 32
APP_TOKEN=

# Unraid GraphQL endpoint. Unraid 7+ serves it through the webUI nginx on
# port 80 (NOT :3001 — that's a legacy doc URL). Leave as-is on the host.
UNRAID_API_URL=http://localhost/graphql

# Create with:
#   unraid-api apikey --create --name "unraid monitor backend" --roles ADMIN
UNRAID_API_KEY=

# -----------------------------------------------------------------------------
# APNs push (optional — backend boots without these, push is disabled)
# -----------------------------------------------------------------------------

# Apple Developer → Membership details → Team ID (10 chars)
APNS_TEAM_ID=

# Apple Developer → Keys → + → Apple Push Notifications service
# Note the 10-char Key ID and download the .p8 file (Apple shows it once).
APNS_KEY_ID=

# Drop the .p8 into backend/data/ — it becomes /data/ inside the container.
APNS_KEY_PATH=/data/AuthKey_<KEYID>.p8

# Must exactly match the iOS app's bundle identifier (ios/project.yml).
APNS_BUNDLE_ID=com.example.unraidmonitor

# -----------------------------------------------------------------------------
# Intervals (optional; defaults shown)
# -----------------------------------------------------------------------------
# NOTIFICATIONS_POLL_INTERVAL_MS=30000
# SAMPLER_INTERVAL_MS=10000

# -----------------------------------------------------------------------------
# Cloudflare Zero Trust Access (optional, used only by the iOS app)
# -----------------------------------------------------------------------------
# If you protect <PUBLIC_URL> with an Access "Service Auth" policy, paste the
# service-token values here for reference / rotation. The backend itself does
# NOT read these — the iOS app sends them as CF-Access-Client-Id/Secret
# headers (stored in Keychain after the user pastes them in Settings).
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Identity / endpoint metadata (used by docs, deploy tooling, iOS setup)
# -----------------------------------------------------------------------------

# Public HTTPS URL exposed by the Cloudflare Tunnel, e.g.
#   https://unraid.your-domain.pl
PUBLIC_URL=https://<PUBLIC_HOST>

# iOS bundle ID (keep in sync with APNS_BUNDLE_ID and ios/project.yml)
IOS_BUNDLE_ID=com.example.unraidmonitor

# -----------------------------------------------------------------------------
# deploy.sh targets (not read by the backend, only by the script)
# -----------------------------------------------------------------------------

# SSH target for rsync/compose. No default — deploy.sh aborts if unset.
UNRAID_HOST=root@<UNRAID_IP>

# Where the backend lives on the Unraid host.
REMOTE_PATH=/mnt/user/appdata/unraid-monitor/backend

# Docker container name (shared by compose and deploy.sh subcommands).
CONTAINER=unraid-monitor-backend
